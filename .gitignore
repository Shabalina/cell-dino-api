# Ignore python temporary files
__pycache__/
*.pyc
.env

# Ignore Mac system files
.DS_Store

# Ignore local virtual environments
venv/
.venv/

# Jupyter Notebook checkpoints
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# IPython history and config
.ipython/
profile_default/
ipython_config.py

# Local terraform directory
**/.terraform/*

# State files
*.tfstate
*.tfstate.*

# Variables files (might contain secrets)
*.tfvars
*.tfvars.json

# Crash logs
crash.log

# Streamlit secrets
*/.streamlit/*

python/
deps_layer.zip